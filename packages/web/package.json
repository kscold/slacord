{
    "name": "@slacord/web",
    "version": "1.0.6",
    "description": "Slacord 웹 프론트엔드 (Next.js)",
    "private": true,
    "scripts": {
        "dev": "next dev --port 3002",
        "build": "next build",
        "start": "next start --port 3002",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
        "clean": "rm -rf .next node_modules"
    },
    "dependencies": {
        "@blocknote/core": "^0.47.2",
        "@blocknote/react": "^0.47.2",
        "@floating-ui/dom": "^1.7.4",
