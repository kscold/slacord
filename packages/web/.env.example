# Next.js 환경변수 예시

# API Server URL (NestJS 서버)
# 프로덕션: https://api.slacord.cloud
# 개발: http://localhost:8082
NEXT_PUBLIC_API_URL=http://localhost:8082

# Socket.IO 서버 URL (선택)
# API와 웹 origin이 다를 때만 지정
# 예시: http://localhost:8082
NEXT_PUBLIC_SOCKET_URL=

# WebRTC ICE/TURN 서버 설정 (선택)
# 비워두면 기본 Google STUN 서버를 사용
# JSON 배열/객체 또는 comma-separated URL 모두 지원
# 예시:
# NEXT_PUBLIC_WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.example.com:3478"]},{"urls":"turn:turn.example.com:3478?transport=udp","username":"slacord","credential":"change-me"}]
NEXT_PUBLIC_WEBRTC_ICE_SERVERS=

# ICE transport policy (all | relay)
# 사내망/NAT 환경에서 TURN 강제가 필요하면 relay 사용
NEXT_PUBLIC_WEBRTC_ICE_TRANSPORT_POLICY=all
